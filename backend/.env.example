# Sarvam AI
SARVAM_API_KEY=
SARVAM_CHAT_MODEL=
SARVAM_TRANSLATE_MODEL=
# Crop disease: AWS Rekognition labels -> Sarvam-M diagnosis (vision model not used)

# PostgreSQL Database Configuration
# Option 1: Supabase PostgreSQL (current)
# Direct connection (IPv6 - use POOL_URL on Windows/IPv4-only networks)
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
# Transaction pooler (IPv4-compatible)
# DATABASE_POOL_URL=postgresql://postgres.xxx:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Option 2: AWS RDS PostgreSQL (recommended for full AWS stack)
# Direct connection with SSL (recommended)
# DATABASE_URL=postgresql://postgres:PASSWORD@agrisaarthi-db.abc123xyz.ap-south-1.rds.amazonaws.com:5432/agrisaarthi?sslmode=require
# For RDS, use same URL for pooling (RDS manages connections internally) OR use RDS Proxy:
# DATABASE_POOL_URL=postgresql://postgres:PASSWORD@agrisaarthi-proxy.proxy-abc.ap-south-1.rds.amazonaws.com:5432/agrisaarthi?sslmode=require

# Active Configuration (update with your choice):
DATABASE_URL=
DATABASE_POOL_URL=

# AWS — S3 + Redis only (fill in if using)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_NAME=
S3_REGION=

BUCKET_URL=s3://agri-translate-kb-mumbai/knowledge-base/insurance-schemes/
BEDROCK_AGRI_KB_ID="" 
BEDROCK_INSURANCE_KB_ID = ""           # From Step 2
BEDROCK_GUARDRAIL_ID = ""  # From Step 3
BEDROCK_GUARDRAIL_VERSION = ""             # From Step 3
BEDROCK_CLAUDE_MODEL_ID = "anthropic.claude-3-haiku-20240307-v1:0"  # Fallback only (not available in ap-south-1)
BEDROCK_NOVA_LITE_MODEL_ID = "amazon.nova-lite-v1:0"   # Direct model ID (converse API)
BEDROCK_NOVA_PRO_MODEL_ID  = "amazon.nova-pro-v1:0"    # Direct model ID (converse API)
# Inference profiles — REQUIRED for RetrieveAndGenerate / Knowledge Base APIs
# ap. prefix = Asia Pacific cross-region profile (ap-south-1, ap-southeast-1, etc.)
BEDROCK_NOVA_LITE_PROFILE_ID = "apac.amazon.nova-lite-v1:0"
BEDROCK_NOVA_PRO_PROFILE_ID  = "apac.amazon.nova-pro-v1:0"


# Redis / AWS ElastiCache Serverless with Valkey (Recommended for production)
# Development: redis://localhost:6379/0 (local Redis/Valkey)
# Production Serverless: rediss://agri-cache.serverless.aps1.cache.amazonaws.com:6379
# Production Fixed Node: redis://master.agri-cache.xxxxx.ap-south-1.cache.amazonaws.com:6379
# See AWS_ELASTICACHE_SETUP.md for configuration (saves ~$500+/month on Bedrock KB costs!)
# Serverless Valkey is RECOMMENDED: Auto-scales, pay-per-use ($9-28/month vs $24-48 fixed)
REDIS_URL= #redis://localhost:6379/0
REDIS_CACHE_ENABLED=true  # Set to false to disable caching (for testing)

# Weather (no key needed)
WEATHER_API_BASE=https://api.open-meteo.com/v1

# Market
ENAM_API_BASE=https://api.enam.gov.in/web/api/trade-data

# App
APP_NAME=AgriSaarthi
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:5173","http://localhost:4173","http://127.0.0.1:3000","http://127.0.0.1:3001","http://127.0.0.1:5173"]
SECRET_KEY=
RATE_LIMIT_PER_MINUTE=60

# Resend — email verification (get your key at https://resend.com)
RESEND_API_KEY=




