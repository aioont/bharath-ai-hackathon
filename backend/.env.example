# ============================================================
# Sarvam AI  (https://sarvam.ai) — Primary AI / Translation
# ============================================================
SARVAM_API_KEY=sk_
# Chat & Reasoning model for Indian languages
SARVAM_CHAT_MODEL=sarvam-m
# Translation model (22 Indian languages)
SARVAM_TRANSLATE_MODEL=sarvam-translate:v1
# Vision model for crop-disease image analysis
SARVAM_VISION_MODEL=sarvam-vision

# ============================================================
# Database — Supabase PostgreSQL
# Direct connection  (IPv6 — use pooler on IPv4-only hosts)
# ============================================================
DATABASE_URL=
# Transaction pooler — IPv4-compatible (e.g. serverless / Windows)
DATABASE_POOL_URL=
# ============================================================
# AWS — minimal usage (S3 image storage + ElastiCache Redis)
# ============================================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-south-1
# S3 — stores uploaded crop images only
S3_BUCKET_NAME=agri-translate-images
S3_REGION=ap-south-1
# Redis (AWS ElastiCache) — rate-limit & API response cache
REDIS_URL=redis://your-elasticache-endpoint:6379/0

# ============================================================
# Weather API — Open-Meteo (free, no key required)
# ============================================================
WEATHER_API_BASE=https://api.open-meteo.com/v1

# ============================================================
# Market Data — AGMARKNET / eNAM (free government API)
# ============================================================
ENAM_API_KEY=your_enam_api_key
ENAM_API_BASE=https://api.enam.gov.in/web/api/trade-data

# ============================================================
# App Settings
# ============================================================
APP_NAME=Agri-Translate AI
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","https://agri-translate.your-domain.com"]
SECRET_KEY=your_super_secret_key_change_this_in_production

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
